// Nextflow auto-loads this file because it sits next to main.nf.
// It turns on Docker so every process runs inside our image.

docker {
  enabled = true
  // On Apple Silicon, force amd64 so the bioconda-based image runs under emulation.
  runOptions = '--platform=linux/amd64'
}

// Default container for all processes (each process can still override it).
process {
  container = 'variant-calling:latest'
}
